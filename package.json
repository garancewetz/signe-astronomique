{
  "name": "signe-astronomique",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Cockpit web that computes your true astronomical sign — the constellation the Sun was actually in at your birth, using IAU 1930 boundaries, equinox precession, and Ophiuchus as the 13th sign. Renders a Cesium 3D globe + geocentric celestial sphere with interactive bodies, a live SGP4-propagated orbital population, and side / depth views of the chosen constellation.",
  "author": {
    "name": "Garance Wetzel",
    "url": "https://github.com/garancewetz"
  },
  "license": "MIT",
  "homepage": "https://signe-astronomique.netlify.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/garancewetz/signe-astronomique.git"
  },
  "bugs": {
    "url": "https://github.com/garancewetz/signe-astronomique/issues"
  },
  "keywords": [
    "astronomy",
    "astrology",
    "cesium",
    "react",
    "typescript",
    "vite",
    "constellations",
    "iau",
    "sgp4",
    "satellites",
    "celestrak",
    "ophiuchus",
    "precession",
    "webgl"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@floating-ui/react": "0.27.16",
    "cesium": "1.140.0",
    "framer-motion": "12.38.0",
    "html2canvas-pro": "2.0.2",
    "jspdf": "4.2.1",
    "lucide-react": "1.14.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "satellite.js": "5.0.0",
    "tailwind-merge": "3.5.0",
    "tz-lookup": "6.1.25"
  },
  "knip": {
    "ignore": [
      "src/types/tz-lookup.d.ts"
    ]
  },
  "overrides": {
    "brace-expansion": "5.0.6",
    "protobufjs": "8.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "25.9.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.6.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.60.1",
    "vite": "8.0.16",
    "vite-plugin-cesium": "1.2.23",
    "vite-plugin-pwa": "1.3.0"
  }
}
